# OpenAI-compatible LLM provider.
#
# Both regular chat models (gpt-4o-mini, Qwen3-32B, moonshot-v1-8k,
# deepseek-chat, ...) and reasoning models (DeepSeek-R1, QwQ,
# deepseek-v*-pro, OpenAI o1/o3) are supported. Reasoning models
# generally produce higher-quality structured analysis but burn extra
# tokens on internal chain-of-thought before emitting the answer — give
# them a generous LLM_MAX_TOKENS (≥ 8000, 16000 is safer for daily
# reports against the structured JSON schema). With too small a budget
# they get truncated mid-thinking and return empty content.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-openai-compatible-key
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=180

# Optional notification webhooks.
# Enable the matching channel in config/config.yaml before using these.
WECHAT_WORK_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token

# FRED API key (free, register at https://fred.stlouisfed.org/docs/api/api_key.html).
# Used by the global market data layer for US Treasury yields (DGS10/DGS5/DGS3MO),
# VIX (VIXCLS), and USD/CNY (DEXCHUS). When unset, the FRED provider is skipped
# and ChainedProvider falls back to Stooq / AKShare for the same data.
FRED_API_KEY=your-fred-api-key

# Alternate OpenAI-compatible examples:
# LLM_PROVIDER=siliconflow
# LLM_MODEL=Qwen/Qwen3-32B
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=sk-your-siliconflow-key
# LLM_TIMEOUT_SECONDS=180
#
# LLM_PROVIDER=moonshot
# LLM_MODEL=moonshot-v1-8k
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_API_KEY=sk-your-moonshot-key
# LLM_TIMEOUT_SECONDS=180
#
# LLM_PROVIDER=local
# LLM_MODEL=qwen2.5:7b
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=local
# LLM_TIMEOUT_SECONDS=180
